@{
    ViewBag.Title = "Zdravie v rovnováhe - Začnite Novým rokom 2026";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Sales Page Styles */
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        padding: 60px 20px;
        text-align: center;
        border-radius: 12px;
        margin-bottom: 40px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    }
    .hero-section h1 {
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 20px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }
    .hero-section .lead {
        font-size: 20px;
        margin-bottom: 30px;
        line-height: 1.6;
    }
    .cta-primary {
        background: #28a745;
        color: #fff !important;
        padding: 18px 40px;
        font-size: 20px;
        font-weight: 700;
        border-radius: 8px;
        text-decoration: none;
        display: inline-block;
        box-shadow: 0 8px 20px rgba(40,167,69,0.3);
        transition: all 0.3s ease;
        border: none;
    }
    .cta-primary:hover {
        background: #218838;
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(40,167,69,0.4);
        color: #fff !important;
    }
    .benefit-card {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        margin-bottom: 30px;
        transition: transform 0.3s ease;
    }
    .benefit-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }
    .benefit-icon {
        font-size: 48px;
        color: #5d33fb;
        margin-bottom: 15px;
    }
    .testimonial-card {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 25px;
        border-radius: 10px;
        border-left: 4px solid #5d33fb;
        margin-bottom: 20px;
    }
    .price-badge {
        background: #ffcc00;
        color: #2c3e50;
        padding: 8px 20px;
        border-radius: 20px;
        font-size: 18px;
        font-weight: 700;
        display: inline-block;
        margin: 10px 0;
    }
    .guarantee-box {
        background: #e7f3ff;
        border: 2px solid #5d33fb;
        border-radius: 10px;
        padding: 25px;
        margin: 30px 0;
        text-align: center;
    }
    .urgency-banner {
        background: #ff6b6b;
        color: #fff;
        padding: 15px;
        text-align: center;
        border-radius: 8px;
        margin-bottom: 30px;
        font-weight: 600;
    }
    .stats-row {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        margin: 40px 0;
    }
    .stat-item {
        text-align: center;
        flex: 1;
        min-width: 200px;
        margin: 10px;
    }
    .stat-number {
        font-size: 48px;
        font-weight: 700;
        color: #5d33fb;
    }
    .stat-label {
        font-size: 16px;
        color: #666;
        margin-top: 5px;
    }
    @@media (max-width: 768px) {
        .hero-section h1 { font-size: 28px; }
        .hero-section .lead { font-size: 16px; }
        .cta-primary { padding: 14px 30px; font-size: 16px; }
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <h1>🌿 Zmeňte Svoje Zdravie v Roku 2026</h1>
